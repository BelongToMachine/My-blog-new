# Database (PostgreSQL / Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Next.js
NEXT_PUBLIC_DEV_MODE="dev"
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS="false"
NEXT_PUBLIC_PRODUCTION_MODE="static"

# AI chat model is fixed to DeepSeek v4 Flash
DEEPSEEK_API_KEY=sk-...
AI_THINKING_ENABLED=false

# Resend — transactional email for contact form (https://resend.com)
# Free tier: 100 emails/day
RESEND_API_KEY=re_...
CONTACT_RECIPIENT_EMAIL=your-email@gmail.com

# Upstash Redis (required for production rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MDX blog content path
PRIVATE_BLOG_CONTENT_PATH=""

# Dev secret token (for local API protection)
NEXT_PUBLIC_DEV_SECRET_TOKEN=""
